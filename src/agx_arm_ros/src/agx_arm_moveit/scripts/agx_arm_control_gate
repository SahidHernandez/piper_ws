#!/usr/bin/env python3
# -*-coding:utf8-*-
import rclpy
from rclpy.node import Node
from action_msgs.msg import GoalStatusArray
from std_srvs.srv import SetBool


class ControlGate(Node):
    def __init__(self):
        super().__init__("control_gate")
        self.declare_parameter(
            "status_topics",
            ["arm_controller/follow_joint_trajectory/_action/status"],
        )
        self.declare_parameter("gate_service_name", "control_enable")

        self.status_topics = list(self.get_parameter("status_topics").value)
        self.gate_service_name = self.get_parameter("gate_service_name").value

        self._active_states = {1, 2, 3}  # ACCEPTED, EXECUTING, CANCELING
        self._gate_open = None
        self._service_ready_logged = False
        self._topic_is_active = {}

        self._gate_client = self.create_client(SetBool, self.gate_service_name)
        for topic in self.status_topics:
            self._topic_is_active[topic] = False
            self.create_subscription(
                GoalStatusArray,
                topic,
                lambda msg, t=topic: self._status_callback(msg, t),
                10,
            )

        self._ready_timer = self.create_timer(0.2, self._ensure_initial_gate_closed)
        self.get_logger().info(
            f"Control gate started. status_topics={self.status_topics}, "
            f"gate_service_name={self.gate_service_name}"
        )

    def _ensure_initial_gate_closed(self):
        if not self._gate_client.wait_for_service(timeout_sec=0.0):
            return
        if not self._service_ready_logged:
            self.get_logger().info("Gate service is ready, forcing gate closed")
            self._service_ready_logged = True
        self._set_gate(False)
        self._ready_timer.cancel()

    def _status_callback(self, msg: GoalStatusArray, topic_name: str):
        self._topic_is_active[topic_name] = any(
            status.status in self._active_states for status in msg.status_list
        )
        self._set_gate(any(self._topic_is_active.values()))

    def _set_gate(self, open_gate: bool):
        if self._gate_open is open_gate:
            return
        if not self._gate_client.wait_for_service(timeout_sec=0.0):
            return

        request = SetBool.Request()
        request.data = open_gate
        self._gate_client.call_async(request)
        self._gate_open = open_gate
        state = "opened" if open_gate else "closed"
        self.get_logger().info(f"External control gate {state} by execution status")


def main(args=None):
    rclpy.init(args=args)
    node = ControlGate()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        rclpy.shutdown()


if __name__ == "__main__":
    main()
